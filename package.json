{
    "name": "job-scraper-lambda",
    "version": "1.0.0",
    "description": "job scraper — Apify + OpenAI + Neon (TypeScript)",
    "type": "module",
    "main": ".eslintrc.js",
    "scripts": {
        "build": "sam validate --lint && sam build --cached --parallel --use-container --skip-pull-image --build-in-source",
        "deploy": "sam deploy --no-confirm-changeset",
        "delete": "aws cloudformation delete-stack --stack-name event-management-platform",
        "typecheck": "tsc --noEmit",
        "db:generate": "npx drizzle-kit generate",
        "db:migrate": "npx drizzle-kit migrate",
        "lambda": "sam local invoke MainLambda --env-vars env.json"
    },
    "dependencies": {
        "@neondatabase/serverless": "^0.10.4",
        "drizzle-orm": "^0.45.1",
        "esbuild": "^0.27.3",
        "pg": "^8.19.0"
    },
    "devDependencies": {
        "@types/aws-lambda": "^8.10.145",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.16.0",
        "drizzle-kit": "^0.31.9",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.7.0"
    }
}
